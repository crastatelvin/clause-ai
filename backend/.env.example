# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: comma-separated list of allowed origins for CORS (defaults to *)
# ALLOWED_ORIGINS=http://localhost:3000,https://clause.example.com

# Optional: max upload size in megabytes (defaults to 10)
# MAX_UPLOAD_MB=10
